# Production deployment example.
# Most hosts provide PORT automatically. Keep HOST as 0.0.0.0 for public web services.
HOST=0.0.0.0
PORT=4175

# Keep this conservative for free hosting.
SCHEDULER_INTERVAL_MS=300000

# Optional Supabase auth proxy values.
# Leave these unset for the public demo if you are not enabling accounts yet.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Add this locally when running the deployment smoke test script.
PINGVISTA_DEPLOYMENT_URL=https://your-pingvista-url.onrender.com
